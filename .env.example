# ── FundPilot 环境变量配置 ────────────────────────────────────
# 复制此文件为 .env 并根据部署环境修改各参数值。
# 所有变量均被 docker-compose.yml 和后端服务使用。
# ──────────────────────────────────────────────────────────────

# 服务
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# CORS（逗号分隔的允许来源，"*" 表示全部放行）
CORS_ORIGINS=*

# 数据库
DB_USER=fundpilot
DB_PASSWORD=change-me
DB_NAME=fundpilot
DB_PORT=5432
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# 测试数据库端口（仅用于 docker-compose --profile test）
TEST_DB_PORT=5433

# 前端接口鉴权（逗号分隔，留空=不开启鉴权）
API_KEYS=

# 数据库敏感数据加密密钥（用于加密 AI 供应商 API 密钥）
# 生成命令: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# PyPI 镜像（Docker 构建时使用，境外环境可删掉此项）
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple

# 国内金融数据源代理绕过（逗号分隔的域名列表）
NO_PROXY=eastmoney.com,10jqka.com.cn,sina.com.cn,cls.cn,jin10.com,wallstreetcn.com,sse.com.cn,szse.cn,csindex.com.cn

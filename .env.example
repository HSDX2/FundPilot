# ── FundPilot Environment Variables ─────────────────────────────────────
# Copy this file to .env and adjust values for your deployment.
# All variables are used by docker-compose.yml and the backend service.
# ────────────────────────────────────────────────────────────────────────

# Server
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# CORS (comma-separated origins, "*" for all)
CORS_ORIGINS=*

# Database
DB_USER=fundpilot
DB_PASSWORD=change-me
DB_NAME=fundpilot
DB_PORT=5432
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Test database (optional, only used with --profile test)
TEST_DB_PORT=5433

# AI API keys (optional)
OPENAI_API_KEY=
OPENAI_API_BASE=
CLAUDE_API_KEY=

# PyPI mirror (for Docker builds, change if outside China)
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
